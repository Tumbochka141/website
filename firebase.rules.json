{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && ((!data.exists() && newData.child('hostId').val() === auth.uid) || data.child('hostId').val() === auth.uid)",
          "maxPlayers": {
            ".validate": "newData.isNumber() && newData.val() >= 2 && newData.val() <= 4"
          }
        },
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid) && (newData.val() === null || data.exists() || root.child('rooms').child($roomId).child('players').numChildren() < root.child('rooms').child($roomId).child('meta/maxPlayers').val())",
            ".validate": "newData.val() === null || (newData.hasChildren(['name', 'joinedAt']) && newData.child('name').isString() && newData.child('name').val().length <= 24)"
          }
        },
        "public": {
          ".read": "auth != null && root.child('rooms').child($roomId).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid"
        },
        "hands": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid)",
            ".write": "auth != null && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid"
          }
        },
        "engine": {
          ".read": "auth != null && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid",
          ".write": "auth != null && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid"
        },
        "commands": {
          ".read": "auth != null && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid",
          "$commandId": {
            ".write": "auth != null && ((newData.exists() && !data.exists() && newData.child('from').val() === auth.uid && root.child('rooms').child($roomId).child('players').child(auth.uid).exists()) || (!newData.exists() && root.child('rooms').child($roomId).child('meta/hostId').val() === auth.uid))",
            ".validate": "newData.val() === null || (newData.hasChildren(['type', 'from', 'revision']) && newData.child('type').isString() && newData.child('type').val().length <= 20 && newData.child('revision').isNumber())"
          }
        }
      }
    }
  }
}
